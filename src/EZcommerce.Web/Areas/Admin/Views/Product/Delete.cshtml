@model Product
<div class="headerPanel2">
    <h1>Delete Product</h1>
</div>
<br />
<div class="flexCenter">
    <div class="whitePanelCard cardType2">

        <h5>Id: <b>@Model.Id</b></h5>
        <h5>Name: <b>@Model.Name</b></h5>
        <h5>Description: <b>@Model.Description</b></h5>
        <h5>Price: <b>@Model.Price</b></h5>

        <form asp-area="Admin" asp-controller="Product" asp-action="DeleteConfirmed">
            <input type="hidden" asp-for="Id" />
            <button class="btn btn-primary customButton1" type="submit">Delete</button>
        </form>
    </div>

</div>




@using EZcommerce.Web.Models
@model List<EZcommerce.Web.Models.Payment>

<div class="headerPanel">
    <h1>Payment Dashboard</h1>
</div>

<div style="padding:20px">
    <table class="table table-sm">
        <thead class="table-info">
            <tr>
                <th scope="col">Id</th>
                <th scope="col">OrderId</th>
                <th scope="col">Amount</th>
                <th scope="col">Method</th>
                <th scope="col">Status</th>
                <th scope="col">Trans. Refer.</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (Payment payment in Model)
            {
                <tr>
                    <td>@payment.Id</td>
                    <td>@payment.OrderId</td>
                    <td>@payment.Amount</td>
                    <td>@payment.Method</td>
                    <td>@payment.Status</td>
                    <td>@payment.TransactionReference</td>
                    <td>
                        <a asp-area="Admin" asp-controller="Payment" asp-action="Edit" asp-route-id=@payment.Id>
                            Edit
                        </a>
                        |
                        <a asp-area="Admin" asp-controller="Payment" asp-action="Delete" asp-route-id=@payment.Id>
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>


